{
  "name": "tron-grpc",
  "version": "1.0.1",
  "description": "A TypeScript client for interacting with the TRON blockchain via gRPC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tronsave/tron-grpc.git"
  },
  "homepage": "https://github.com/tronsave/tron-grpc#readme",
  "bugs": {
    "url": "https://github.com/tronsave/tron-grpc/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "sync-proto": "tsx scripts/sync-proto.ts",
    "gen-proto": "./gen-ts.sh",
    "update-proto": "npm run sync-proto && npm run gen-proto",
    "build": "npm run clean && tsc --project tsconfig.json && npm run copy-proto && npm run minify",
    "copy-proto": "mkdir -p dist/src/proto/contract && find src/proto -maxdepth 1 -name '*.proto' -exec cp {} dist/src/proto/ \\; && cp src/proto/contract/*.proto dist/src/proto/contract/",
    "minify": "find dist -name '*.js' -exec terser {} -c pure_funcs=[],pure_getters=true,keep_fargs=false,module=true,toplevel=true -m -o {} \\;",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "test": "tsx test.ts",
    "verify": "npm run typecheck && npm run lint && npm test",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/google-protobuf": "^3.15.12",
    "@types/node": "^25.6.0",
    "eslint": "^10.4.1",
    "protoc-gen-ts": "^0.8.7",
    "terser": "^5.46.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/bip39": "^2.2.0",
    "google-protobuf": "^4.0.2",
    "tslib": "^2.8.1"
  }
}
