# Copy to `.env` and fill in. `.env` is git-ignored ‚Äî never commit secrets.

# TronGrid API key (https://www.trongrid.io). Sent as the TRON-PRO-API-KEY
# gRPC metadata header; raises rate limits on the public endpoints.
TRON_PRO_API_KEY=

# Optional client diagnostic logs: silent | error | warn | info | debug
# TRON_GRPC_LOG_LEVEL=debug

# Private key (hex, 64 chars, no 0x) used ONLY by the broadcast test.
# Use a TESTNET key ‚Äî the broadcast test runs on Nile/Shasta, never mainnet.
TRON_PRIVATE_KEY=

# Recipient for the test transfer (base58 "T..." address).
TRON_TO=

# Network the broadcast test targets: nile | shasta (NOT mainnet).
TRON_NETWORK=nile
